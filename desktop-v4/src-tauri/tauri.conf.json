{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aindexer V4",
  "version": "0.1.1",
  "identifier": "local.aindexer.v4",
  "build": {
    "devUrl": "http://127.0.0.1:5173/v3/workbench",
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aindexer V4",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
